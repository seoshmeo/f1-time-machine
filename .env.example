# ===========================================
# F1 Time Machine - Environment Configuration
# ===========================================

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_SEASON=2010

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./db/f1_time_machine.db
ADMIN_API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# --- AI Customization ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_DEFAULT_SEASON=2010

# --- Telegram API ---
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PORT=8443
BACKEND_API_URL=http://backend:8000/api/v1
BOT_ADMIN_CHAT_ID=
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_SEND_TIME=09:00
DEFAULT_LANGUAGE=ru

# --- Data Pipeline ---
JOLPICA_API_BASE=https://api.jolpi.ca/ergast/f1
JOLPICA_RATE_LIMIT=2
